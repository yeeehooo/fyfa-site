{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fyfa-site",
  "main": "_worker.js",
  "compatibility_date": "2026-04-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
